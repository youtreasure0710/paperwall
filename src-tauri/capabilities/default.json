{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default permissions for PaperWall",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen",
    "dialog:default",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}
